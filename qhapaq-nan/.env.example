# =============================================================
# Qhapaq Ñan · Variables de entorno
# =============================================================
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.

# -------------------------------------------------------------
# Supabase
# -------------------------------------------------------------
# Encuentra estos valores en https://app.supabase.com → Project → Settings → API

# URL pública del proyecto (visible en cliente — no es secreto)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon key (visible en cliente — protegida por RLS, no es secreto sensible)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key (SECRETO — solo en servidor, jamás en cliente)
# Salta RLS, úsala solo en endpoints server-side controlados.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -------------------------------------------------------------
# Email (Resend)
# -------------------------------------------------------------
# https://resend.com — usado para magic links y notificaciones críticas
RESEND_API_KEY=re_...

# Dirección de envío configurada en Resend (debe estar verificada)
RESEND_FROM_EMAIL=hola@qhapaqnan.pe

# -------------------------------------------------------------
# Aplicación
# -------------------------------------------------------------
# URL pública del sitio (sin slash final). Usada para magic links y emails.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email del admin para notificaciones del sistema (incidentes, reportes graves)
ADMIN_EMAIL=admin@qhapaqnan.pe

# -------------------------------------------------------------
# Rate limiting (opcional pero recomendado en producción)
# -------------------------------------------------------------
# Usa Upstash Redis (free tier 10k req/día). Si no se setea, rate limit
# se hace en memoria (válido para desarrollo, no para producción multi-instancia).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# -------------------------------------------------------------
# Notas de seguridad
# -------------------------------------------------------------
# - Las claves marcadas como NEXT_PUBLIC_ se incluyen en el bundle del cliente.
# - El resto NUNCA debe aparecer en código del cliente ni en logs.
# - Rota SUPABASE_SERVICE_ROLE_KEY si sospechas filtración: Supabase → Settings → API → Reset.
# - Rota RESEND_API_KEY si sospechas filtración: Resend → API Keys.
