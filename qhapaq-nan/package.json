{
  "name": "qhapaq-nan",
  "version": "0.1.0",
  "private": true,
  "description": "Qhapaq Ñan · Mapa colaborativo del SERUMS peruano",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:gen-types": "supabase gen types typescript --local > src/lib/supabase/types.ts",
    "supabase:gen-types:cloud": "supabase gen types typescript --linked > src/lib/supabase/types.ts",
    "seed": "node --env-file=.env.local ./node_modules/tsx/dist/cli.mjs supabase/seed/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "resend": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "supabase": "^1.207.9",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
